<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
          force="true" é OBRIGATÓRIO: o container de produção define APP_ENV,
          DB_CONNECTION, DB_DATABASE etc. como variáveis de ambiente REAIS, que
          sobrescrevem <env> simples. Sem force, os testes rodam contra o banco de
          PRODUÇÃO (fiscaldock) com RefreshDatabase — risco de wipe. Ver memory
          feedback_phpunit_server_vars. O banco de teste é fiscaldock_test (pgsql).
        -->
        <server name="APP_ENV" value="testing" force="true"/>
        <server name="DB_CONNECTION" value="pgsql" force="true"/>
        <server name="DB_DATABASE" value="fiscaldock_test" force="true"/>
        <server name="CACHE_STORE" value="array" force="true"/>
        <server name="QUEUE_CONNECTION" value="sync" force="true"/>
        <server name="SESSION_DRIVER" value="array" force="true"/>
        <server name="MAIL_MAILER" value="array" force="true"/>
        <server name="BCRYPT_ROUNDS" value="4" force="true"/>
        <!-- Isola os toggles de consultas do .env de prod (allowlist/flag) p/ testes determinísticos -->
        <server name="CONSULTAS_INFOSIMPLES_ATIVO" value="false" force="true"/>
        <server name="CONSULTAS_INFOSIMPLES_TESTE_CNPJS" value="" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
